# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon Postgres
DATABASE_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# AI gateway (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Legacy single-model fallback (used as the MiniMax default if AI_MODEL_MINIMAX_M3 is unset)
OPENROUTER_MODEL=minimax/minimax-m2

# Default AI quality mode: economy | balanced | premium
AI_DEFAULT_MODE=balanced

# Multi-model routing — these defaults are the verified current OpenRouter IDs,
# so they are OPTIONAL. Only set a variable to override a default.
AI_MODEL_GLM_FLASH=z-ai/glm-4.7
AI_MODEL_GLM_FREE=z-ai/glm-4.5-air:free
AI_MODEL_GEMINI_FLASH_LITE=google/gemini-2.5-flash-lite
# MiniMax M3 is not on OpenRouter yet; M2 is the current premium model.
# Set this to minimax/minimax-m3 once it is published.
AI_MODEL_MINIMAX_M3=minimax/minimax-m2
AI_MODEL_QWEN_CODER=qwen/qwen3-coder-flash

# Number of section agents to run in parallel
GENERATION_CONCURRENCY=5

# Optional attribution sent to OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AI BOQ Agent
