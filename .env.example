# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon Postgres
DATABASE_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Required for internal generation route calls in deployed environments.
# Generate a long random value and keep it server-side only.
INTERNAL_WORKER_SECRET=

# AI gateway (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Legacy single-model fallback (used as the MiniMax default if AI_MODEL_MINIMAX_M3 is unset)
OPENROUTER_MODEL=minimax/minimax-m2

# Default AI quality mode: economy | balanced | premium
AI_DEFAULT_MODE=balanced

# Multi-model routing — these defaults are the verified current OpenRouter IDs,
# so they are OPTIONAL. Only set a variable to override a default.
AI_MODEL_GLM_FLASH=z-ai/glm-4.7
AI_MODEL_GLM_FREE=z-ai/glm-4.5-air:free
AI_MODEL_GEMINI_FLASH_LITE=google/gemini-2.5-flash-lite
# MiniMax M3 is not on OpenRouter yet; M2 is the current premium model.
# Set this to minimax/minimax-m3 once it is published.
AI_MODEL_MINIMAX_M3=minimax/minimax-m2
AI_MODEL_QWEN_CODER=qwen/qwen3-coder-flash

# Number of section agents to run in parallel. Keep this modest to avoid
# upstream model 429/500 spikes when many BOQ sections run at once.
GENERATION_CONCURRENCY=3

# Section-agent generation limits. Lower values are faster and less likely to
# hit provider output limits; increase only for very large sections.
SECTION_AGENT_MAX_TOKENS=9000
SECTION_AGENT_MAX_CHUNKS=18

# Retry transient model 429/5xx errors before falling back to the next model.
AI_MODEL_RETRIES=2

# Abort an individual AI request after this many ms (prevents a hung model call
# from stalling a generation).
AI_REQUEST_TIMEOUT_MS=120000

# Vision-based drawing interpretation (on when an API key is present; set to
# "false" to disable and keep image placeholders instead).
VISION_ENABLED=true
PDF_VISION_MAX_PAGES=3

# Semantic search / RAG retrieval (opt-in). Requires an embeddings model that
# outputs 1536-dim vectors (document_chunks.embedding is vector(1536)).
EMBEDDINGS_ENABLED=false
EMBEDDINGS_MODEL=openai/text-embedding-3-small
# Defaults to OPENROUTER_BASE_URL / OPENROUTER_API_KEY if unset.
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=

# Optional attribution sent to OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AI BOQ Agent
