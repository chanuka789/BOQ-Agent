# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon Postgres
DATABASE_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# AI gateway (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Legacy single-model fallback (used as the MiniMax default if AI_MODEL_MINIMAX_M3 is unset)
OPENROUTER_MODEL=minimax/minimax-m3

# Default AI quality mode: economy | balanced | premium
AI_DEFAULT_MODE=balanced

# Multi-model routing — set these to the exact OpenRouter model IDs for your account.
# If a default below is wrong for your account, override it here.
AI_MODEL_GLM_FLASH=z-ai/glm-4.6
AI_MODEL_GLM_FREE=z-ai/glm-4.5-air:free
AI_MODEL_GEMINI_FLASH_LITE=google/gemini-2.5-flash-lite
AI_MODEL_MINIMAX_M3=minimax/minimax-m3
AI_MODEL_QWEN_CODER=qwen/qwen3-coder

# Number of section agents to run in parallel
GENERATION_CONCURRENCY=5

# Optional attribution sent to OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AI BOQ Agent
